{
  "manifest_version": 2,
  "name": "AV Text Paster",
  "version": "1.0",
  "description": "Send selected text to Sakura title.txt / actress.txt",
  "permissions": [
    "contextMenus",
    "nativeMessaging"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "av-text-paster@example.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
