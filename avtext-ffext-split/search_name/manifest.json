{
  "manifest_version": 2,
  "name": "AV Text Checker",
  "version": "1.5",
  "description": "Check selected actress name via native host and show Registered/Unregistered overlay",
  "permissions": [
    "nativeMessaging"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "av-text-check@example.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
