{
  "manifest_version": 2,
  "name": "AVText - focus",
  "version": "1.0",
  "description": "Focus Sakura Editor",
  "permissions": [
    "contextMenus",
    "nativeMessaging"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "av-text-focus@example.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
