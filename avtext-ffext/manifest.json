{
  "manifest_version": 2,
  "name": "AV Text Paster",
  "version": "1.8",
  "description": "Send selected text to Sakura title.txt / actress.txt / no.txt",
  "permissions": [
    "contextMenus",
    "nativeMessaging"
  ],
  "icons": {
    "16": "icons/avtext-16.svg",
    "32": "icons/avtext-32.svg"
  },
  "browser_action": {
    "default_title": "AV Text Paster 設定",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/avtext-16.svg",
      "32": "icons/avtext-32.svg"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "av-text-paster@example.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
